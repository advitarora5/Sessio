# Supabase (browser-safe)
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Supabase (server-only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Ollama (server-only — local install needs no API key)
# Install: https://ollama.com — then run `ollama pull llama3.2`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# Optional — only required for Ollama Cloud (https://ollama.com/cloud)
OLLAMA_API_KEY=
